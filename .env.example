# AI QR Art Generator — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is gitignored.

# fal.ai API key — used for QR code art generation via ControlNet models
# Get yours at https://fal.ai/dashboard/keys
FAL_KEY=

# Stripe secret key — server-side only, never expose to browser
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# Stripe webhook signing secret — validates that webhook payloads come from Stripe
# Get from https://dashboard.stripe.com/webhooks after creating an endpoint
STRIPE_WEBHOOK_SECRET=

# Stripe publishable key — safe to expose in browser (NEXT_PUBLIC_ prefix is intentional)
# Get from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs for subscription tiers
# Create in Stripe Dashboard → Products → Add Product
# Pro: $9/month recurring
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=
# Business: $29/month recurring
NEXT_PUBLIC_STRIPE_BUSINESS_PRICE_ID=

# Base URL for the app — used for Stripe redirect URLs and canonical SEO links
NEXT_PUBLIC_APP_URL=http://localhost:4827
