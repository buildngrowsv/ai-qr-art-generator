# Required — set these before deploying

# fal.ai API key for QR art generation
FAL_KEY=

# Stripe payment integration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Price IDs from Stripe Dashboard (recurring monthly) — required for /api/stripe/checkout
NEXT_PUBLIC_STRIPE_PRICE_ID_PRO=
NEXT_PUBLIC_STRIPE_PRICE_ID_BUSINESS=

# Optional: hosted Payment Links (buy.stripe.com/...) — work without Checkout API
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_PRO=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_BUSINESS=

# App URL (used for Stripe checkout success/cancel redirects)
NEXT_PUBLIC_APP_URL=http://localhost:4827

# --- Upstash Redis — durable sliding-window rate limits ---
# Required for server-side rate limiting. Create a database at
# https://console.upstash.com/ → copy REST URL + token.
# Set the same names on Vercel → Environment Variables (Production).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
