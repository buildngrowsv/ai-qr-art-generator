# AI QR Art Generator - Environment Variables
# Copy this file to .env.local and fill in real values

# fal.ai API key - used for QR code art generation via ControlNet models
# Get yours at https://fal.ai/dashboard/keys
FAL_KEY=your_fal_key_here

# Stripe secret key - server-side API calls for payment processing
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe webhook signing secret - validates webhook payloads from Stripe
# Get from https://dashboard.stripe.com/webhooks after creating an endpoint
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe publishable key - client-side, safe to expose in browser
# Get from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Stripe Price IDs for subscription tiers
# Create these in Stripe Dashboard > Products > Add Product
# Pro: $9/month recurring
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_pro_placeholder
# Business: $29/month recurring
NEXT_PUBLIC_STRIPE_BUSINESS_PRICE_ID=price_business_placeholder

# Base URL for the app - used for Stripe redirect URLs
NEXT_PUBLIC_APP_URL=http://localhost:4827
